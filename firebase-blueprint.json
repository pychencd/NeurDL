{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user information and AI quota.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "aiQuota": { "type": "number", "description": "Remaining AI optimization requests." },
        "isPremium": { "type": "boolean" }
      },
      "required": ["email", "aiQuota"]
    },
    "Download": {
      "title": "Download Task",
      "description": "Stores a single download task for a user.",
      "type": "object",
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "filename": { "type": "string" },
        "size": { "type": "number" },
        "progress": { "type": "number" },
        "status": { "type": "string", "enum": ["downloading", "paused", "completed", "error"] },
        "addedAt": { "type": "number" },
        "protocol": { "type": "string" }
      },
      "required": ["url", "filename", "status", "addedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and quota information."
    },
    "/users/{userId}/downloads/{downloadId}": {
      "schema": "Download",
      "description": "User's download tasks."
    }
  }
}
